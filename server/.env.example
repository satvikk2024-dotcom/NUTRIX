# Port the Express API listens on (defaults to 5055 if unset)
PORT=5055

# MongoDB connection string. Currently unused — connectDB() is not called
# in server.js, so the app runs fine without this. Set it if you re-enable
# database persistence (see FUTURE.md).
MONGO_URI=mongodb://localhost:27017/nutrix

# Gemini API key (free tier: 1500 req/day) — primary AI source
GEMINI_API_KEY=your-gemini-api-key-here

# Ollama configuration — fallback when Gemini is unavailable
# Ollama must be running locally: ollama serve
OLLAMA_HOST=http://localhost:11434
OLLAMA_VISION_MODEL=llava:7b
OLLAMA_TEXT_MODEL=qwen2.5:7b
